{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "pinDependencies",
    "group:allNonMajor",
    "mergeConfidence:all-badges",
    "security:openssf-scorecard",
    ":enablePreCommit",
    ":disableDependencyDashboard"
  ],

  "labels": ["dependencies", "no-stale"],

  "vulnerabilityAlerts": {
    "addLabels": ["security"]
  }
}
