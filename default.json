{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":pinDependencies",
    "group:allNonMajor",
    "group:allDigest",
    "mergeConfidence:all-badges",
    "security:openssf-scorecard",
    ":enablePreCommit",
    ":semanticCommits",
    ":disableDependencyDashboard"
  ],

  "labels": ["dependencies", "no-stale"],

  "vulnerabilityAlerts": {
    "addLabels": ["security"]
  },

  "prConcurrentLimit": 0,
  "prHourlyLimit": 5,

  "timezone": "UTC"
}
